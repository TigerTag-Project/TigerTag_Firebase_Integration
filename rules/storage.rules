// ─────────────────────────────────────────────────────────────────────
// TigerTag Cloud Storage Security Rules — TARGET state
//
// The TigerTag Firebase project's bucket serves TWO surfaces:
//
//   1. Public CDN assets (filament product photos, printer thumbnails,
//      etc.) — uploaded by Cloud Functions / Admin SDK, served by
//      cdn.tigertag.io (which 302s to a Firebase Storage URL). These
//      MUST be world-readable; clients consume them anonymously through
//      `<img src="https://cdn.tigertag.io/img?id=...">`.
//
//   2. User-owned blobs that mirror a Firestore field (avatars today;
//      conceivably print-photos or larger profile media tomorrow). Each
//      such path follows the rule of thumb "Storage is the blob,
//      Firestore is the index" — a Firestore field always points at the
//      Storage path so we can find the blob from the user doc.
//
// Auth model:
//   - READ on CDN assets is public (the catch-all `if true` below).
//   - READ on the user-owned `avatars/{uid}` namespace is signed-in
//     only — consistent with `userProfiles` visibility in Firestore.
//   - WRITE on the CDN catch-all is locked to admin/Cloud Functions
//     (deny-all from the client side; Admin SDK bypasses rules).
//   - WRITE on `avatars/{uid}` is gated to the owner with size and
//     MIME constraints.
//
// To deploy:
//   firebase deploy --only storage
//
// ─────────────────────────────────────────────────────────────────────

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 👤 User avatars                                              ║
    // ║                                                              ║
    // ║ Path: avatars/{uid}                                          ║
    // ║   - Single file per user, predictable path → re-uploading    ║
    // ║     overwrites the previous avatar (no orphan blobs).        ║
    // ║   - File extension is NOT in the path. The mime is carried   ║
    // ║     by the object's Content-Type header (set on upload).     ║
    // ║     Clients accept JPEG, PNG and WebP.                       ║
    // ║                                                              ║
    // ║ Index: userProfiles/{uid}.photoURL                           ║
    // ║   - The download URL (with its access token) is mirrored in  ║
    // ║     the user's userProfile doc. The token rotates on every   ║
    // ║     upload, which acts as natural cache-busting for clients  ║
    // ║     that already hold an older URL.                          ║
    // ║   - Absence of photoURL → client falls back to the colour    ║
    // ║     circle + initials avatar.                                ║
    // ║                                                              ║
    // ║ Visibility:                                                  ║
    // ║   - Read by any signed-in user. This intentionally matches   ║
    // ║     the Firestore visibility of userProfiles itself — the    ║
    // ║     friend-add preview flow (resolve XXX-XXX code → render   ║
    // ║     pseudo + avatar BEFORE sending the request) depends on   ║
    // ║     the avatar being readable without a prior friendship.    ║
    // ║   - Write by owner only.                                     ║
    // ║                                                              ║
    // ║ Upload constraints (enforced server-side):                   ║
    // ║   - Max 200 KB. Typical client-side-resized 512×512 avatars  ║
    // ║     land at 15–50 KB JPEG / 80–180 KB PNG-with-alpha — the   ║
    // ║     200 KB cap rejects raw 5 MB phone photos and forces the  ║
    // ║     client to do the resize.                                 ║
    // ║   - Content-Type must be image/jpeg, image/png, or image/    ║
    // ║     webp. SVG, GIF (animated), TIFF and BMP are blocked      ║
    // ║     deliberately — SVG can carry script, GIF is a            ║
    // ║     compositor cost we don't want, the others have no use    ║
    // ║     case for avatars.                                        ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /avatars/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 200 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
      // Deleting an avatar is the owner's right (revert to colour
      // circle fallback). The client should also clear userProfiles
      // .photoURL in the same operation, but the rule here only
      // gates the blob.
      allow delete: if request.auth != null
                    && request.auth.uid == uid;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 🌐 Public CDN assets (filament photos, printer thumbnails…)  ║
    // ║                                                              ║
    // ║ Path: anything NOT matched by a rule above (e.g.             ║
    // ║   filament/large/{id}.jpg, filament/small/{id}.jpg,          ║
    // ║   printers/{brand}/{id}.png, etc.).                          ║
    // ║                                                              ║
    // ║ Served by cdn.tigertag.io which 302-redirects to a Firebase  ║
    // ║ Storage download URL — must be world-readable for the redirect ║
    // ║ to be usable by anonymous browser clients hitting <img src>. ║
    // ║                                                              ║
    // ║ Writes are denied from the client side. The catalogue is     ║
    // ║ populated by Cloud Functions / Admin SDK, which bypass these ║
    // ║ rules entirely.                                              ║
    // ║                                                              ║
    // ║ DO NOT remove this rule without first auditing every CDN-    ║
    // ║ consuming client (Studio, mobile, third-party) — switching   ║
    // ║ to default-deny here broke `https://cdn.tigertag.io/img?id=N`║
    // ║ between commits 9d780cb and the fix in the same session.    ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
