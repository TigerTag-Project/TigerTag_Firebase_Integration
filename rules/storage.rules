// ─────────────────────────────────────────────────────────────────────
// TigerTag Cloud Storage Security Rules
//
// Strict allowlist model: every public-read path is enumerated below.
// Anything not matched falls through to the catch-all DEFAULT-DENY
// block at the bottom. This is the inverse of "open by default" and
// is what the previous production rules already enforced (ruleset
// 245321d6, deployed 2025-10-23) — never relax this without first
// auditing every consuming client.
//
// Two kinds of paths:
//
//   1. Public CDN assets (filament/, resin/, media/, files/) —
//      world-readable, no client write. Populated by Cloud Functions /
//      Admin SDK, served by cdn.tigertag.io which 302-redirects to a
//      Firebase Storage URL.
//
//   2. User-owned blobs (avatars/) — owner-write, signed-in read.
//      Mirror a Firestore field that points at the blob.
//
// And one explicitly-denied path (uploads/) for temporary admin
// staging buffers that must NEVER leak.
//
// To deploy:
//   firebase deploy --only storage
//
// ─────────────────────────────────────────────────────────────────────

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 👤 User avatars                                              ║
    // ║                                                              ║
    // ║ Path: avatars/{uid}                                          ║
    // ║   - Single file per user, predictable path → re-uploading    ║
    // ║     overwrites the previous avatar (no orphan blobs).        ║
    // ║   - File extension is NOT in the path. The mime is carried   ║
    // ║     by the object's Content-Type header (set on upload).     ║
    // ║     Clients accept JPEG, PNG and WebP.                       ║
    // ║                                                              ║
    // ║ Index: userProfiles/{uid}.photoURL                           ║
    // ║   - The download URL (with its access token) is mirrored in  ║
    // ║     the user's userProfile doc. The token rotates on every   ║
    // ║     upload, which acts as natural cache-busting for clients  ║
    // ║     that already hold an older URL.                          ║
    // ║   - Absence of photoURL → client falls back to the colour    ║
    // ║     circle + initials avatar.                                ║
    // ║                                                              ║
    // ║ Visibility:                                                  ║
    // ║   - Read by any signed-in user. Matches the Firestore        ║
    // ║     visibility of userProfiles itself — the friend-add       ║
    // ║     preview flow (resolve XXX-XXX code → render pseudo +     ║
    // ║     avatar BEFORE sending the request) depends on the avatar ║
    // ║     being readable without a prior friendship.               ║
    // ║   - Write by owner only.                                     ║
    // ║                                                              ║
    // ║ Upload constraints (enforced server-side):                   ║
    // ║   - Max 500 KB. Typical client-side-resized 512×512 avatars  ║
    // ║     land at 15–50 KB JPEG / 60–180 KB PNG-with-alpha. The    ║
    // ║     500 KB ceiling leaves headroom for detailed transparent  ║
    // ║     PNGs (illustrations, complex memojis) while still         ║
    // ║     rejecting raw multi-megabyte phone photos uploaded raw.  ║
    // ║   - Content-Type must be image/jpeg, image/png, or image/    ║
    // ║     webp. SVG / GIF / TIFF / BMP blocked deliberately.       ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /avatars/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 500 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow delete: if request.auth != null
                    && request.auth.uid == uid;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 🌐 Public CDN — media/ (UploadMedia outputs)                 ║
    // ║ Path: media/{folder}/{mediaType}/{fileId}.{ext}              ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /media/{folder}/{mediaType}/{fileId} {
      allow read: if true;
      allow write: if false;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 🌐 Public CDN — filament product images                      ║
    // ║ Path: filament/{size}/{fileId} (e.g. filament/large/10.jpg)  ║
    // ║ Served by https://cdn.tigertag.io/img?id={n}                 ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /filament/{size}/{fileId} {
      allow read: if true;
      allow write: if false;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 🌐 Public CDN — resin product images                         ║
    // ║ Path: resin/{size}/{fileId}                                  ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /resin/{size}/{fileId} {
      allow read: if true;
      allow write: if false;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 🌐 Public CDN — brand-scoped files (PDFs, etc.)              ║
    // ║ Path: files/{brandId}/{path...}                              ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /files/{brandId}/{fileName=**} {
      allow read: if true;
      allow write: if false;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 🚫 Temporary admin upload buffers — STRICTLY denied          ║
    // ║                                                              ║
    // ║ Path: uploads/{productType}/{productId}/{file}               ║
    // ║                                                              ║
    // ║ The admin pipeline lands raw uploads here before processing  ║
    // ║ (resize / dedupe / move to filament/resin/media). Clients    ║
    // ║ must NEVER read or write this surface — Admin SDK uses it    ║
    // ║ via privileged bypass. Denying explicitly (vs. relying on    ║
    // ║ the catch-all) makes the intent loud in the rules file.      ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /uploads/{productType}/{productId}/{file} {
      allow read, write: if false;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 🛡️  Default deny — everything else                          ║
    // ║                                                              ║
    // ║ Any path not matched above falls here and is fully denied.   ║
    // ║ To open a new surface, add an explicit `match` block above.  ║
    // ║                                                              ║
    // ║ This restores the same default-deny posture as the previous  ║
    // ║ production ruleset (245321d6 / 2025-10-23). It was briefly   ║
    // ║ relaxed to `read: if true` between commits 9d780cb and       ║
    // ║ c76b643 to fix a CDN regression caused by an incorrect       ║
    // ║ catch-all in the very first storage.rules deploy — see the   ║
    // ║ CHANGELOG entry for the post-mortem.                          ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
