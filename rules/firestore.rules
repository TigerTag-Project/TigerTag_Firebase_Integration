// ─────────────────────────────────────────────────────────────────────
// TigerTag Firestore Security Rules — TARGET state
//
// This file shows the rules in their TARGET form, including the
// `request.query.limit` guards on list operations. These limit guards
// are NOT yet enforced in production — we are in a soft-rollout window:
//
//   • The deployed rules currently allow unbounded list reads (no .limit()
//     required). This protects clients running older Tiger Studio /
//     mobile app versions that don't yet pass .limit() on every query.
//
//   • Cloud Audit Logs are watching `google.firestore.v1.Firestore.RunQuery`
//     events. We track how often clients issue list reads without .limit()
//     or with .limit() > 200 (50 for racks). When violations drop to
//     ~zero across all client versions, the strict rules below will be
//     deployed.
//
//   • Third-party integrations (HA, ESP32, scripts) should build to
//     this TARGET spec from day one. Always include .limit(N) on every
//     list read. Your client will be future-proof for the cutover.
//
// Status, monitoring data, and rollout schedule are tracked in
// docs/05-rate-limiting.md and CHANGELOG.md.
// ─────────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 🔎 Firestore health check (used by /healthz?deep=1)          ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /_healthz_probe/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 🌐 Public profiles — readable by any authenticated user      ║
    // ║ Contains : publicKey, displayName, isPublic, color_r/g/b     ║
    // ║ Does NOT contain : privateKey, email, inventory              ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /userProfiles/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 🔑 Public-key index  publicKeys/{key} → { uid }              ║
    // ║ O(1) lookup by doc id — guarantees XXX-XXX code uniqueness   ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /publicKeys/{key} {
      // Any signed-in user can resolve a code (used in friend lookup flow)
      allow read: if request.auth != null;
      // Only the owner can claim / release their own code
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 👤 Private user document (1 doc = 1 user)                    ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /users/{userId} {

      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      allow create: if isOwner();
      allow read, update, delete: if isOwner();

      // ── API Keys ──────────────────────────────────────────────────
      match /apiKeys/{docId} {
        allow read, write: if isOwner();
      }

      // ── Printers ──────────────────────────────────────────────────
      match /printers/{brand}/{document=**} {
        allow read, write: if isOwner();
      }

      // ── Preferences ───────────────────────────────────────────────
      match /prefs/{prefId} {
        allow read, write: if isOwner();
      }

      // ── Inventory ─────────────────────────────────────────────────
      // Read allowed if:
      //   1. Owner
      //   2. Inventory is public (isPublic = true in userProfiles)
      //   3. Accepted friend — mere presence in the friends list is enough.
      //      No key check needed: creating the friends/{me} entry is already
      //      gated by the prior existence of a friend request (see rule
      //      below), so users can't self-add.
      // Anti-flood guard: `list` is capped at 200 docs per request.
      // Single-doc reads (`get`) are unrestricted.
      match /inventory/{itemId} {
        allow write: if isOwner();
        allow get:   if isOwner()
          || get(/databases/$(database)/documents/userProfiles/$(userId)).data.isPublic == true
          || (
            request.auth != null
            && exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))
          );
        allow list:  if (
            isOwner()
            || get(/databases/$(database)/documents/userProfiles/$(userId)).data.isPublic == true
            || (
              request.auth != null
              && exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))
            )
          )
          && request.query.limit != null
          && request.query.limit <= 200;
      }

      // ── Incoming friend requests ──────────────────────────────────
      // Bob can create HIS request on Alice's account (unless blacklisted).
      // Alice alone can read, update (accept/refuse), or delete.
      match /friendRequests/{requesterId} {
        allow create: if request.auth != null
          && request.auth.uid == requesterId
          && !exists(/databases/$(database)/documents/users/$(userId)/blacklist/$(requesterId));
        allow read, update, delete: if isOwner();
        // Bob can also delete his own pending request (cancel)
        allow delete: if request.auth != null && request.auth.uid == requesterId;
      }

      // ── Accepted friends ──────────────────────────────────────────
      // Alice manages her list — Bob can read HIS own entry (to fetch his key)
      // ISO acceptance: the acceptee can write his entry into the requester's list
      //   (request.auth.uid == friendId AND a request from userId exists at friendId)
      // Symmetric removal: a friend can remove themselves from the other's list.
      match /friends/{friendId} {
        allow read:  if isOwner()
          || (request.auth != null && request.auth.uid == friendId);
        allow write: if isOwner();
        // The acceptee can create their own entry in the requester's friends list
        allow create: if request.auth != null
          && request.auth.uid == friendId
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/friendRequests/$(userId));
        // Either party can remove themselves from the other's list
        allow delete: if request.auth != null
          && request.auth.uid == friendId;
      }

      // ── Blacklist ─────────────────────────────────────────────────
      match /blacklist/{blockedId} {
        allow read, write: if isOwner();
      }

      // ── Storage racks ─────────────────────────────────────────────
      // Read: same policy as inventory — owner / public / friends.
      // Write: owner only.
      // Anti-flood guard: `list` is capped at 50 racks per request
      // (any normal user has < 20 racks; the cap is intentionally tight).
      match /racks/{rackId} {
        allow write: if isOwner();
        allow get:   if isOwner()
          || get(/databases/$(database)/documents/userProfiles/$(userId)).data.isPublic == true
          || (
            request.auth != null
            && exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))
          );
        allow list:  if (
            isOwner()
            || get(/databases/$(database)/documents/userProfiles/$(userId)).data.isPublic == true
            || (
              request.auth != null
              && exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))
            )
          )
          && request.query.limit != null
          && request.query.limit <= 50;
      }

      // ── Products (per product-IDENTITY: favorites, buy link, price…) ─
      // Tiger Studio "Products & Favorites" feature. One doc per product
      // identity (doc id = keyHash of the product signature, NOT a spoolId),
      // so the info applies to every identical spool and survives a spool's
      // deletion. Read: same policy as inventory / racks (owner / public /
      // friends) — friends read this directly to see each other's favorites,
      // buy link + price, and full material info (`cloudSeed`). Write: owner.
      // NOTE: the `note` field ("un mot pour ton futur toi") lives here and is
      // therefore friend-readable — assumed product tradeoff to avoid a
      // duplicated collection; the apps never surface a friend's note.
      // Anti-flood guard: `list` capped at 200 docs per request.
      match /products/{keyHash} {
        allow write: if isOwner();
        allow get:   if isOwner()
          || get(/databases/$(database)/documents/userProfiles/$(userId)).data.isPublic == true
          || (
            request.auth != null
            && exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))
          );
        allow list:  if (
            isOwner()
            || get(/databases/$(database)/documents/userProfiles/$(userId)).data.isPublic == true
            || (
              request.auth != null
              && exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))
            )
          )
          && request.query.limit != null
          && request.query.limit <= 200;
      }

      // ── Scales (TigerScale heartbeats) ────────────────────────────
      // Private — the ESP32 scale authenticates as the owner and writes
      // its own heartbeat. No third-party access.
      match /scales/{mac} {
        allow read, write: if isOwner();
      }

      // ── UID migration map (decimal legacy → hex canonical) ────────
      // See `docs/clients/tigerscale-doc-schema.md` § UID format. Each
      // entry's doc id is the legacy decimal UID; the body carries the
      // matching hex doc id. Lookups via this map let any client holding
      // an old decimal UID resolve it to the canonical hex doc.
      // Read: owner AND accepted friends (a friend may hold a decimal
      // UID picked up from this user's earlier inventory snapshot).
      // Write: owner only.
      match /uidMigrationMap/{decimalUid} {
        allow read:  if isOwner()
          || (
            request.auth != null
            && exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))
          );
        allow write: if isOwner();
      }
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║ 📦 Media indexes (admin / Cloud Functions only)              ║
    // ╚══════════════════════════════════════════════════════════════╝
    match /mediaIndex/{folder} {
      allow read, write: if false;
      match /byId/{id} {
        allow read, write: if false;
      }
    }
    match /mediaIndex_product/{id} {
      allow read, write: if false;
    }
    match /mediaIndex_serie/{id} {
      allow read, write: if false;
    }
    match /mediaIndex/{legacyId} {
      allow read, write: if false;
    }
  }
}
